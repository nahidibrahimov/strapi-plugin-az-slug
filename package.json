{
  "name": "strapi-plugin-az-slug",
  "version": "0.1.0",
  "description": "A Strapi plugin that provides an Azerbaijani-aware slug custom field with frontend slug generation and availability check.",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "slug",
    "slugify",
    "azerbaijani",
    "custom-field",
    "cms"
  ],
  "license": "MIT",
  "author": "Nahid Ibrahimov <nahidibrahimovv@gmail.com>",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "tsc -p admin/tsconfig.json --noEmit",
    "test:ts:back": "tsc -p server/tsconfig.json --noEmit"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-plugin-az-slug",
    "displayName": "AZ Slug",
    "description": "A custom slug field for Strapi with Azerbaijani transliteration and slug availability check."
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/strapi": "^5.38.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.39.0",
    "@strapi/typescript-utils": "^5.39.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "strapi-plugin-az-slug": "file:.yalc/strapi-plugin-az-slug"
  }
}
